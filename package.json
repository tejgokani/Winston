{
  "name": "winston_sec_mcp",
  "version": "0.1.0",
  "description": "AI-assisted security auditing MCP server with an interactive threat graph.",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/tejgokani/Winston.git"
  },
  "type": "module",
  "bin": {
    "winston-mcp": "./dist/server.js",
    "winston": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run copy-assets",
    "copy-assets": "node -e \"const fs=require('fs'); fs.cpSync('src/playbooks','dist/playbooks',{recursive:true}); fs.cpSync('src/ui/static','dist/ui/static',{recursive:true});\"",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate-playbooks": "tsx scripts/validatePlaybooks.ts",
    "prepublishOnly": "rm -rf dist && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.2",
    "gray-matter": "^4.0.3",
    "graphology": "^0.26.0",
    "graphology-utils": "^2.5.2",
    "web-tree-sitter": "^0.24.6",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
